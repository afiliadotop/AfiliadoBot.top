# Backend API URL (local)
# Use /api para usar o proxy do Vite (recomendado para desenvolvimento)
# Em produção, defina a URL completa do backend
VITE_API_URL=/api

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHANNEL_ID=-1001234567890
# IDs dos admins do bot (separe por vírgula se tiver mais de um)
# Para descobrir seu ID: mande qualquer mensagem para @userinfobot no Telegram
ADMIN_IDS=123456789,987654321

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# Telethon (Ghost Protocol Worker)
TELETHON_API_ID=your_api_id
TELETHON_API_HASH=your_api_hash
TELETHON_PHONE=+5511999999999

# Shopee Affiliates API
SHOPEE_APP_ID=18353920154
SHOPEE_APP_SECRET=your_shopee_secret_here
SHOPEE_API_ENDPOINT=https://open-api.affiliate.shopee.com.br/graphql

# Shopee Import Settings
SHOPEE_AUTO_SYNC_ENABLED=true
SHOPEE_SYNC_INTERVAL_HOURS=24
SHOPEE_MIN_COMMISSION_RATE=5.0

# Monitoring
VITE_SENTRY_DSN=your_sentry_dsn_here

# Mercado Livre Affiliates API
ML_ACCESS_TOKEN=your_ml_access_token_here
ML_REFRESH_TOKEN=your_ml_refresh_token_here
ML_APP_ID=your_app_id_here
ML_SECRET_KEY=your_secret_key_here
ML_AFFILIATE_TAG=your_affiliate_tag_here

# ------------------------------------------------------------------
# Affiliate Bot Tools (skill: affiliate-bot-tools)
# ------------------------------------------------------------------
AMAZON_AFFILIATE_TAG=afiliadotop-20
SHOPEE_AFFILIATE_ID=your_shopee_affiliate_id
ML_AFFILIATE_ID=afiliadotop
ALIEXPRESS_AFFILIATE_ID=your_aliexpress_affiliate_id

# Desconto falso: se preco_declarado > media_historica * threshold → fake
FAKE_DISCOUNT_THRESHOLD=1.1

# URL base dos links internos de rastreio de cliques
INTERNAL_REDIRECT_BASE=https://afiliado.top/go

# ------------------------------------------------------------------
# Runtime
# ------------------------------------------------------------------
ADMIN_API_KEY=your_strong_random_admin_key
CRON_TOKEN=your_cron_token_for_github_actions
RUN_SCHEDULER=false
RENDER_EXTERNAL_URL=https://your-app.onrender.com

# ------------------------------------------------------------------
# Commission Junction (CJ) Affiliate API
# ------------------------------------------------------------------
# Gere em: https://accounts.cj.com/affui/affiliate/personalAccessTokens
CJ_API_TOKEN=your_cj_personal_access_token_here
# Seu Company ID / CID (CJ Account Manager → Manage Accounts)
CJ_COMPANY_ID=your_cj_company_id_here
# PID do seu site na CJ (CJ Account Manager → Campanhas → Links → dropdown do site)
# Usado em linkCode(pid) para gerar links de afiliado rastreáveis
CJ_PID=your_cj_pid_here

# ------------------------------------------------------------------
# Awin Affiliate API
# ------------------------------------------------------------------
# Publisher ID (encontrado em: https://ui.awin.com/awin/publisher/account)
AWIN_PUBLISHER_ID=your_awin_publisher_id_here
# API Token (gere em: https://ui.awin.com/awin/publisher/account/api-token)
AWIN_API_TOKEN=your_awin_api_token_here
